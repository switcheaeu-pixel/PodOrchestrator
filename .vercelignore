# Ignore everything except frontend
*

# Allow frontend directory
!frontend/

# Within frontend, ignore development files
frontend/.next
frontend/node_modules
frontend/coverage
frontend/.storybook
frontend/storybook-static
frontend/*.log
frontend/.env.local
frontend/.env.*.local

# Ignore test files
frontend/**/*.test.*
frontend/**/*.spec.*

# Ignore backup files
frontend/**/*.bak
frontend/**/*.tmp

# Allow necessary files
!frontend/package.json
!frontend/package-lock.json
!frontend/yarn.lock
!frontend/next.config.js
!frontend/tailwind.config.js
!frontend/postcss.config.js
!frontend/tsconfig.json
!frontend/.eslintrc.json
!frontend/app/
!frontend/public/