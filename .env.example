# Podcast AI Platform - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
APP_NAME=PodcastAI
APP_VERSION=1.0.0
LOG_LEVEL=info

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
BACKEND_PORT=3001
FRONTEND_PORT=3000
AI_SERVICES_PORT=8000
CORS_ORIGIN=http://localhost:3000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=podcast_ai
DB_USER=podcast_user
DB_PASSWORD=podcast_password
DB_SSL=false
DB_POOL_MAX=20

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0
REDIS_TTL=86400 # 24 hours in seconds

# ============================================
# Authentication & Security
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_key

# ============================================
# AI Service API Keys
# ============================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG=org-your-organization-id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google AI
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# AssemblyAI (Transcription)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Descript (Audio Editing)
DESCRIPT_API_KEY=your-descript-api-key

# ============================================
# Cloud Services
# ============================================

# AWS (for S3, Polly TTS)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-south-1 # Milan region for Italian users
S3_BUCKET=podcast-ai-audio
S3_ENDPOINT= # Leave empty for AWS, set for MinIO

# Google Cloud (for TTS, Speech-to-Text)
GOOGLE_CLOUD_CREDENTIALS=path/to/your/google-credentials.json
GOOGLE_CLOUD_PROJECT=your-google-cloud-project

# ============================================
# Local AI Models (Optional)
# ============================================
LOCAL_LLM_ENABLED=false
LOCAL_LLM_PATH=/models/llama-italian
LOCAL_LLM_DEVICE=cpu # or cuda
LOCAL_TTS_ENABLED=false
LOCAL_TTS_MODEL=italian-tts-model

# ============================================
# Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@podcastai.it
EMAIL_VERIFICATION_ENABLED=true

# ============================================
# Payment & Billing (Stripe)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
CURRENCY=EUR

# ============================================
# Monitoring & Analytics
# ============================================
SENTRY_DSN=your-sentry-dsn-url
GA_TRACKING_ID=UA-XXXXX-Y
MIXPANEL_TOKEN=your-mixpanel-token

# ============================================
# Feature Flags
# ============================================
FEATURE_VOICE_CLONING=true
FEATURE_VIDEO_PODCAST=false
FEATURE_LIVE_RECORDING=false
FEATURE_TEAM_COLLABORATION=false

# ============================================
# Italian Market Specific
# ============================================
DEFAULT_LANGUAGE=it
SUPPORTED_LANGUAGES=it,en,es,fr,de
ITALIAN_REGIONAL_ACCENTS=true
ITALIAN_CULTURAL_REFERENCES=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_FREE=10
RATE_LIMIT_CREATOR=50
RATE_LIMIT_PRO=200
RATE_LIMIT_BUSINESS=1000

# ============================================
# Cache Configuration
# ============================================
CACHE_ENABLED=true
CACHE_TTL=3600 # 1 hour
CACHE_MAX_ITEMS=10000

# ============================================
# File Upload Limits
# ============================================
MAX_FILE_SIZE=104857600 # 100MB
ALLOWED_AUDIO_TYPES=mp3,wav,ogg,m4a
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif

# ============================================
# Podcast Distribution
# ============================================
RSS_FEED_ENABLED=true
APPLE_PODCASTS_ENABLED=false
SPOTIFY_ENABLED=false
GOOGLE_PODCASTS_ENABLED=false

# ============================================
# Development & Debugging
# ============================================
DEBUG=true
SEED_DATABASE=false
ENABLE_SWAGGER=true
ENABLE_GRAPHIQL=false

# ============================================
# External Service URLs
# ============================================
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
AI_SERVICES_URL=http://localhost:8000
MINIO_URL=http://localhost:9000
MAILHOG_URL=http://localhost:8025